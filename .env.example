# Copy this file to .env and fill in the values

MONGODB_URI=your_mongodb_connection_string
PORT=5000

# Admin Login Password
ADMIN_SECRET=your_strong_admin_password

# JWT Secret (long random string)
JWT_SECRET=your_long_random_jwt_secret

# Allowed Frontend Origins (comma separated)
ALLOWED_ORIGINS=https://fz-cricket-tournament.vercel.app,http://localhost:5173

# UPI Payment IDs
UPI_GPAY=your_gpay_upi_id
UPI_PHONEPE=your_phonepe_upi_id
UPI_PAYTM=your_paytm_upi_id

# Cloudinary (for image uploads)
CLOUDINARY_URL=your_cloudinary_url

# Firebase Admin SDK (paste entire JSON as single line string)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
