# Copy this file to .env and fill in your values

# MongoDB Atlas Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/fz_cricket

# Server Port
PORT=5000

# Admin Panel Password (use a strong password)
ADMIN_SECRET=your_strong_admin_password

# JWT Secret (use a long random string, min 32 chars)
JWT_SECRET=your_very_long_random_jwt_secret_key_here

# Razorpay Payment Keys (Optional)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Cloudinary Image Upload (Optional)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Allowed CORS Origins (comma-separated)
ALLOWED_ORIGINS=https://your-frontend.netlify.app,http://localhost:5173
